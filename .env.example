# Copy to .env and edit values as needed

# Camera mapping
FRONT_CAMERA_INDEX=0
REAR_CAMERA_INDEX=1
# Set 1 if front/rear view is swapped
CAMERA_SWAP=0

# YOLO model
YOLO_MODEL_PATH=/home/besstsu/Documents/AmazingRobot/best1.pt
TARGET_CLASSES=FaceWoodenbox,woodenbox
PRIORITY_CLASS=FaceWoodenbox
CONF_THRESHOLD=0.5
YOLO_MAX_DET=20
APPROACH_MIN_NORM=0.18
APPROACH_MAX_NORM=0.45
APPROACH_ERR_SLOW_GAIN=0.65
APPROACH_NEAR_SLOW_GAIN=0.45
ENTRY_ALIGN_LATERAL_TOL_PX=28
ENTRY_ALIGN_HEADING_TOL_NORM=0.08
ENTRY_ALIGN_HOLD_FRAMES=6
ENTRY_ALIGN_TURN_GAIN=0.9
ENTRY_ALIGN_HEADING_GAIN=0.5
ENTRY_ALIGN_TURN_NORM=0.30
ENTRY_ALIGN_FORWARD_NORM=0.12
PRE_APRIL_BBOX_TOLERANCE_PX=10
PRE_APRIL_ADJUST_NORM=0.18
PRE_APRIL_ADJUST_TIMEOUT_SEC=6.0
STUCK_WINDOW_SEC=1.2
STUCK_MIN_PROGRESS_CM=0.6
STUCK_MAX_RETRIES=3
STUCK_BACKOFF_SEC=0.8
STUCK_BACKOFF_NORM=0.26
STUCK_TURN_SEC=0.7
STUCK_TURN_NORM=0.30

# Optional line trigger
BBOX_TRIGGER_LINE_Y=360
PLANT_TO_CAMBACK_POINT_CM=0.0
NO_BOX_STOP_FRAMES=8
VISION_LOOP_SEC=0.03
STATUS_LOOP_SEC=0.05
PLANT_LIMIT_TIMEOUT_SEC=8.0
PLANT_LIMIT_GRACE_SEC=12.0
PLANT_UP_STEP_TIMEOUT_SEC=20.0
SERVO_PLANT_AFTER_DEG=0
STEP1_AFTER_BURRIED_DEG=4500

# ServoCam speed tuning
SERVO_CAM_STEP_DEG=3
SERVO_CAM_STEP_INTERVAL_SEC=0.04
SERVO_CAM_FAST_PX_THRESHOLD=40
SERVO_CAM_FAST_MAX_MULTIPLIER=5

# Rear measurement (cabbage size)
REAR_MEASURE_TARGET_CLASS=cabbage
REAR_MEASURE_FRAMES=8
REAR_MEASURE_TIMEOUT_SEC=3.0
REAR_MEASURE_SIZE_THRESHOLD_CM=12.0
MOVE_TO_MEASURE_SPEED_NORM=0.28
REAR_MEASURE_MAX_PER_CLASS=5
REAR_MEASURE_MAX_TOTAL=5

# Calibration
APRILTAG_SIZE_CM=5.0
APRILTAG_FX=0.0
APRILTAG_FY=0.0
APRILTAG_CX=0.0
APRILTAG_CY=0.0
APRILTAG_HFOV_DEG=0.0
APRILTAG_VFOV_DEG=0.0
APRILTAG_COARSE_ALIGN_ENABLED=1
APRILTAG_COARSE_ALIGN_TOL_PX=24
APRILTAG_COARSE_ALIGN_HOLD_FRAMES=4
APRILTAG_COARSE_ALIGN_TURN_GAIN=0.85
APRILTAG_COARSE_ALIGN_TURN_NORM=0.22
APRILTAG_COARSE_ALIGN_FORWARD_NORM=0.05
APRILTAG_COARSE_ALIGN_TIMEOUT_SEC=2.5
APRILTAG_TRIANGLE_ALIGN_ENABLED=1
APRILTAG_TRIANGLE_STANDOFF_CM=20.0
APRILTAG_TRIANGLE_MAX_MOVE_CM=120.0
APRILTAG_TRIANGLE_MAX_TURN_DEG=75.0
APRILTAG_TRIANGLE_MOVE_NORM=0.24
APRILTAG_TRIANGLE_TURN_TIMEOUT_SEC=4.0
APRILTAG_TRIANGLE_MOVE_TIMEOUT_SEC=8.0
APRILTAG_TRIANGLE_TURN2_DEG=90.0
APRILTAG_TRIANGLE_FINAL_HEADING_OFFSET_DEG=0.0
APRILTAG_ACCEPT_CENTER_TOL_NORM=0.22
APRILTAG_ACCEPT_YAW_DEG=22.0
APRILTAG_FACE_BOX_EXPAND_SCALE=1.35
REAR_CM_PER_PX_DEFAULT=0.05
IMU_ENABLED=0
IMU_TYPE=BNO055
IMU_HEADING_OFFSET_DEG=0.0
IMU_INVERT_HEADING=0
IMU_HEADING_TOLERANCE_DEG=2.5
IMU_TURN_GAIN=0.020
IMU_TURN_NORM_MAX=0.22
